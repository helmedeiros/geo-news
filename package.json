{
  "name": "geo-news",
  "version": "0.0.1",
  "description": "Geolocalised news for the Americas.",
  "main": "lib/index.js",
  "keywords": [
    "news",
    "geo",
    "rss",
    "map",
    "americas"
  ],
  "author": "Helio Medeiros",
  "license": "MIT",
  "engines": {
    "node": ">= 0.6"
  },
  "scripts": {
    "lint": "jshint lib test scripts && jshint --config web/.jshintrc web/js",
    "test": "mocha --reporter spec --recursive test",
    "check": "npm run lint && npm test",
    "build:dataset": "node scripts/build-headlines-dataset.js",
    "deploy:pages": "bash scripts/deploy-pages.sh"
  },
  "devDependencies": {
    "mocha": "~1.2.0",
    "chai": "~1.0.0",
    "jshint": "~0.7.0",
    "grunt": "~0.3.9",
    "grunt-contrib-jshint": "~0.1.0",
    "grunt-mocha-test": "~0.2.0"
  }
}
