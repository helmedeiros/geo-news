{
  "node": true,
  "browser": false,
  "curly": true,
  "eqeqeq": true,
  "undef": true,
  "trailing": true,
  "indent": 2,
  "quotmark": "single",
  "predef": [
    "describe",
    "it",
    "before",
    "after",
    "beforeEach",
    "afterEach",
    "console",
    "process",
    "URL",
    "Buffer"
  ]
}
